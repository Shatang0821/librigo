# --- OS / Editor ---
.DS_Store
.vscode/*
!.vscode/extensions.json
.idea
*.sw?

# --- Docker & Environment ---
.env
*.local
# データベースの永続化ディレクトリ（docker-compose.ymlのvolumesに合わせる）
postgres_data/
docker/db_data/

# --- Backend (Go) ---
# backendフォルダ内のバイナリや依存関係
backend/bin/
backend/vendor/
backend/*.test
backend/*.out
backend/coverage.*
# ビルドされた実行ファイル名
backend/librigo

# --- Frontend (React/Vite) ---
# frontendフォルダ内の重いファイルやビルド成果物
frontend/node_modules/
frontend/dist/
frontend/dist-ssr/
frontend/.vite/
frontend/*.log
# npm/yarn/pnpmのログ
frontend/npm-debug.log*
frontend/yarn-debug.log*
frontend/pnpm-debug.log*

# --- Root levels ---
node_modules/
dist/
*.log